    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "dotenv": "16.4.7",
    "eslint": "^8.57.1",
    "eslint-plugin-markdown": "^3.0.1",
    "nx": "23.0.1",
    "typescript": "catalog:",
    "vite": "catalog:"
