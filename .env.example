# Local development ports
POSTGRES_PORT=5432
KEYCLOAK_PORT=8080

# PostgreSQL local dependency
POSTGRES_DB=live_software
POSTGRES_USER=live_software
POSTGRES_PASSWORD=live_software
DATABASE_URL=postgresql://live_software:live_software@localhost:5432/live_software?schema=public

# Keycloak local dependency
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Shell/API auth wiring
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=live-software
KEYCLOAK_SHELL_CLIENT_ID=live-software-shell
# Optional until the API client/audience mapper exists in Keycloak.
# KEYCLOAK_API_AUDIENCE=live-software-api
KEYCLOAK_CLOCK_SKEW_SECONDS=30
CORS_ORIGIN=http://localhost:8100
