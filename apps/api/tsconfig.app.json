{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"incremental": true,
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "../../dist/apps/api",
		"rootDir": "./src",
		"declaration": false,
		"sourceMap": true,
		"removeComments": false,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"src/**/*.spec.ts",
		"test/**/*.ts"
	]
}
