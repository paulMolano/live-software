{
	"name": "@live-software/api",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "tsx --tsconfig tsconfig.app.json src/main.ts",
		"build": "pnpm run prisma:generate && tsc -p tsconfig.app.json",
		"typecheck": "pnpm run prisma:generate && tsc -p tsconfig.app.json --noEmit",
		"test": "tsx --test test/**/*.spec.ts",
		"build:test": "tsc -p tsconfig.spec.json",
		"prisma": "prisma --config ../../prisma.config.ts",
		"prisma:validate": "prisma validate --config ../../prisma.config.ts",
		"prisma:generate": "prisma generate --config ../../prisma.config.ts",
		"prisma:migrate:dev": "prisma migrate dev --config ../../prisma.config.ts"
	},
	"dependencies": {
		"@live-software/contracts": "workspace:*",
		"@nestjs/common": "11.1.8",
		"@nestjs/config": "4.0.2",
		"@nestjs/core": "11.1.8",
		"@nestjs/platform-express": "11.1.8",
		"@prisma/adapter-pg": "7.8.0",
		"@prisma/client": "7.8.0",
		"pg": "8.16.3",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2"
	},
	"devDependencies": {
		"@types/node": "26.1.0",
		"prisma": "7.8.0",
		"tsx": "4.20.6"
	}
}
