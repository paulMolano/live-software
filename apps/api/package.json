{
	"name": "@live-software/api",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "tsx --tsconfig tsconfig.app.json src/main.ts",
		"build": "tsc -p tsconfig.app.json",
		"typecheck": "tsc -p tsconfig.app.json --noEmit",
		"test": "tsx --test test/**/*.spec.ts",
		"build:test": "tsc -p tsconfig.spec.json"
	},
	"dependencies": {
		"@nestjs/common": "11.1.8",
		"@nestjs/config": "4.0.2",
		"@nestjs/core": "11.1.8",
		"@nestjs/platform-express": "11.1.8",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2"
	},
	"devDependencies": {
		"@types/node": "26.1.0",
		"tsx": "4.20.6"
	}
}
