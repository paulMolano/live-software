{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "contracts",
  "projectType": "library",
  "root": "packages/contracts",
  "sourceRoot": "packages/contracts/src",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/contracts/tsconfig.json --noEmit"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/contracts"],
      "options": {
        "command": "tsc -p packages/contracts/tsconfig.json"
      }
    }
  },
  "tags": ["scope:shared", "type:contract"]
}
