{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "shared-utils",
  "projectType": "library",
  "root": "packages/shared-utils",
  "sourceRoot": "packages/shared-utils/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint \"src/**/*.{ts,tsx,js,jsx}\"",
        "cwd": "packages/shared-utils"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/shared-utils/tsconfig.json --noEmit"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/packages/shared-utils"
      ],
      "options": {
        "command": "tsc -p packages/shared-utils/tsconfig.json"
      }
    }
  },
  "tags": [
    "scope:shared",
    "type:utility"
  ]
}
