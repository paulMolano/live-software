{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "testing",
  "projectType": "library",
  "root": "packages/testing",
  "sourceRoot": "packages/testing/src",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint \"src/**/*.{ts,tsx,js,jsx}\"",
        "cwd": "packages/testing"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/testing/tsconfig.json --noEmit"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/packages/testing"
      ],
      "options": {
        "command": "tsc -p packages/testing/tsconfig.json"
      }
    }
  },
  "tags": [
    "scope:shared",
    "type:testing"
  ]
}
