{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "config",
  "projectType": "library",
  "root": "packages/config",
  "sourceRoot": "packages/config/src",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/config/tsconfig.json --noEmit"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/config"],
      "options": {
        "command": "tsc -p packages/config/tsconfig.json"
      }
    }
  },
  "tags": ["scope:shared", "type:config"]
}
